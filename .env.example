# ─────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────
APP_NAME=Coupon System
ENVIRONMENT=development
DEBUG=true

# ─────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
API_V1_STR=/api/v1

# ─────────────────────────────────────────
# DATABASE (MySQL)
# ─────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=coupon_system

# ─────────────────────────────────────────
# SECURITY
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# ─────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-string

# ─────────────────────────────────────────
# CORS — comma-separated list of allowed origins
# ─────────────────────────────────────────
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500

# ─────────────────────────────────────────
# TELEGRAM BOT
# Get BOT_TOKEN from @BotFather on Telegram
# Get ADMIN_CHAT_ID by sending /start to your bot after running it once
# ─────────────────────────────────────────
BOT_TOKEN=
ADMIN_CHAT_ID=

# ─────────────────────────────────────────
# ADMIN ACCOUNT
# This user must be registered in the database with role=ADMIN
# The Telegram bot logs in as this user to call admin-protected API endpoints
# ─────────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=
